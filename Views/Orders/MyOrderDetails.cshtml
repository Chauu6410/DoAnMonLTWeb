@model DoAnMonLTWeb.Models.Order
@{
    ViewData["Title"] = "Chi tiet don hang";
    var orderItems = Model.OrderDetails ?? Enumerable.Empty<DoAnMonLTWeb.Models.OrderDetail>();
}

<section class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Chi tiet don hang #@Model.Id</h1>
            <p class="text-muted mb-0">Theo doi tinh trang xu ly va thong tin giao hang cua don.</p>
        </div>
        <a asp-controller="Orders" asp-action="MyOrders" class="btn btn-outline-secondary">Quay lai</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Thong tin don hang</h2>
                    <p class="mb-2"><strong>Khach hang:</strong> @Model.CustomerName</p>
                    <p class="mb-2"><strong>So dien thoai:</strong> @Model.Phone</p>
                    <p class="mb-2"><strong>Dia chi giao:</strong> @Model.ShippingAddress</p>
                    <p class="mb-2"><strong>Ghi chu:</strong> @(string.IsNullOrWhiteSpace(Model.Notes) ? "Khong co" : Model.Notes)</p>
                    <p class="mb-2"><strong>Ngay dat:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-2"><strong>Trang thai:</strong> @OrderStatusHelper.Normalize(Model.Status)</p>
                    <p class="mb-0"><strong>Hen giao du kien:</strong> @Model.OrderDate.AddDays(3).ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="h5 mb-3">San pham da dat</h2>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>San pham</th>
                                    <th>So luong</th>
                                    <th>Don gia</th>
                                    <th>Thanh tien</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in orderItems)
                                {
                                    <tr>
                                        <td>@item.Product?.Name</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.Price.ToString("N0") VNĐ</td>
                                        <td>@((item.Quantity * item.Price).ToString("N0")) VNĐ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="3" class="text-end">Tong tien</th>
                                    <th>@orderItems.Sum(item => item.Quantity * item.Price).ToString("N0") VNĐ</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
