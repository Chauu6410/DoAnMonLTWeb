@model DoAnMonLTWeb.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var orderItems = Model.OrderDetails ?? Enumerable.Empty<DoAnMonLTWeb.Models.OrderDetail>();
}

<section class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Chi tiết đơn hàng #@Model.Id</h1>
            <p class="text-muted mb-0">Theo dõi tình trạng xử lý và thông tin giao hàng của đơn.</p>
        </div>
        <div>
            @if (Model.Status == DoAnMonLTWeb.Models.OrderStatusHelper.ChoXuLy)
            {
                <form asp-controller="Orders" asp-action="CancelOrder" asp-route-id="@Model.Id" method="post" style="display:inline-block;" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');" class="me-2">
                    <button type="submit" class="btn btn-outline-danger">Hủy đơn</button>
                </form>
            }
            <a asp-controller="Orders" asp-action="MyOrders" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Thông tin đơn hàng</h2>
                    <p class="mb-2"><strong>Khách hàng:</strong> @Model.CustomerName</p>
                    <p class="mb-2"><strong>Số điện thoại:</strong> @Model.Phone</p>
                    <p class="mb-2"><strong>Địa chỉ giao:</strong> @Model.ShippingAddress</p>
                    <p class="mb-2"><strong>Ghi chú:</strong> @(string.IsNullOrWhiteSpace(Model.Notes) ? "Khong co" : Model.Notes)</p>
                    <p class="mb-2"><strong>Ngày đặt hàng:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-2"><strong>Trạng thái:</strong> @OrderStatusHelper.Normalize(Model.Status)</p>
                    <p class="mb-0"><strong>Hẹn giao dự kiến:</strong> @Model.OrderDate.AddDays(3).ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="h5 mb-3">Sản phẩm đã đặt</h2>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>San pham</th>
                                    <th>So luong</th>
                                    <th>Don gia</th>
                                    <th>Thanh tien</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in orderItems)
                                {
                                    <tr>
                                        <td>@item.Product?.Name</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.Price.ToString("N0") VNÐ</td>
                                        <td>@((item.Quantity * item.Price).ToString("N0")) VNÐ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="3" class="text-end">Tong tien</th>
                                    <th>@orderItems.Sum(item => item.Quantity * item.Price).ToString("N0") VNÐ</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
