@model IEnumerable<DoAnMonLTWeb.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<section class="container py-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Đơn hàng của tôi</h1>
            <p class="text-muted mb-0">Theo dõi trạng thái các đơn hàng bạn đã đặt.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body py-5 text-center">
                <h2 class="h5">Bạn chưa có đơn hàng nào</h2>
                <p class="text-muted mb-3">Hãy đặt đơn đầu tiên để theo dõi trạng thái tại đây.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Xem sản phẩm</a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Địa chỉ</th>
                            <th>Số sản phẩm</th>
                            <th>Trạng thái</th>
                            <th>Hẹn giao dự kiến</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>#@order.Id</td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@order.ShippingAddress</td>
                                <td>@(order.OrderDetails?.Sum(item => item.Quantity) ?? 0)</td>
                                <td><span class="badge bg-warning text-dark">@OrderStatusHelper.Normalize(order.Status)</span></td>
                                <td>@order.OrderDate.AddDays(3).ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-controller="Orders" asp-action="MyOrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Xem chi tiết</a>
                                        @if (order.Status == DoAnMonLTWeb.Models.OrderStatusHelper.ChoXuLy)
                                        {
                                            <form asp-controller="Orders" asp-action="CancelOrder" asp-route-id="@order.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Hủy đơn</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
