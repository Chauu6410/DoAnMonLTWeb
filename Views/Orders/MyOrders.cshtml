@model IEnumerable<DoAnMonLTWeb.Models.Order>
@{
    ViewData["Title"] = "Don hang cua toi";
}

<section class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Don hang cua toi</h1>
            <p class="text-muted mb-0">Theo doi trang thai cac don hang ban da dat.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Tiep tuc mua sam</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body py-5 text-center">
                <h2 class="h5">Ban chua co don hang nao</h2>
                <p class="text-muted mb-3">Hay dat don dau tien de theo doi trang thai tai day.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Xem san pham</a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ma don</th>
                            <th>Ngay dat</th>
                            <th>Dia chi</th>
                            <th>So san pham</th>
                            <th>Trang thai</th>
                            <th>Hen giao du kien</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>#@order.Id</td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@order.ShippingAddress</td>
                                <td>@(order.OrderDetails?.Sum(item => item.Quantity) ?? 0)</td>
                                <td><span class="badge bg-warning text-dark">@OrderStatusHelper.Normalize(order.Status)</span></td>
                                <td>@order.OrderDate.AddDays(3).ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a asp-controller="Orders" asp-action="MyOrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Xem chi tiet</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
