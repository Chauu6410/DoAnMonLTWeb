@model DoAnMonLTWeb.Models.Product

<div class="container mt-4">

    <div class="row">

        <!-- Hình sản phẩm -->
        <div class="col-md-5">
            <img src="~/images/products/@Model.Image"
                 class="img-fluid rounded shadow">
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-7">

            <h2>@Model.Name</h2>

            <div class="text-warning mb-2">
                ★★★★☆
                <span class="text-dark">(4.9)</span>
            </div>

            <h3 class="text-danger">
                @Model.Price.ToString("N0") VNĐ
            </h3>

            <p class="text-muted">
                Tồn kho: @Model.Stock
            </p>

            <p class="mt-3">
                @Model.Description
            </p>

            @if (Model.Stock > 0)
            {
                <a asp-controller="Cart"
                   asp-action="AddToCart"
                   asp-route-id="@Model.Id"
                   class="btn btn-primary">
                    Thêm vào giỏ hàng
                </a>
            }
            else
            {
                <button type="button" class="btn btn-secondary" disabled>Hết hàng</button>
            }

        </div>

    </div>

    <hr>

    <!-- Đánh giá -->
    <h4>Đánh giá sản phẩm</h4>

    <div class="border p-3 mb-2 rounded">
        <strong>Lý Yến Nhi</strong>
        <div class="text-warning">★★★★★</div>
        <p>Sản phẩm rất tốt, chất lượng đúng mô tả.</p>
    </div>

    <div class="border p-3 mb-2 rounded">
        <strong>Huỳnh Khánh Băng</strong>
        <div class="text-warning">★★★★☆</div>
        <p>Ổn trong tầm giá.</p>
    </div>
    <div class="border p-3 mb-2 rounded">
        <strong>Hà Nhựt Khôi</strong>
        <div class="text-warning">★★★★★</div>
        <p>Sản phẩm tốt, giá cả phù hợp.</p>
    </div>
    <div class="border p-3 mb-2 rounded">
        <strong>Chung Hoàng Khang</strong>
        <div class="text-warning">★★★★★</div>
        <p>Phù hợp với tầm giá.</p>
    </div>
</div>
