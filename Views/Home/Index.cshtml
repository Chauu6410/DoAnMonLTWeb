@model IEnumerable<DoAnMonLTWeb.Models.Product>

@{
    ViewData["Title"] = "Trang chu";
}

<section class="hero-panel">
    <span class="hero-badge"><i class="fas fa-bolt"></i> Hang moi ve moi tuan</span>
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <h1 class="hero-title">Phu kien dien thoai dep, ben va san sang giao nhanh</h1>
            <p class="hero-text">
                Kham pha bo suu tap linh kien va phu kien danh cho nguoi dung thich su gon gang, chinh hang va de chon mua.
            </p>
            <div class="hero-stats">
                <div class="hero-stat">
                    <strong>@Model.Count()</strong>
                    <span>San pham noi bat</span>
                </div>
                <div class="hero-stat">
                    <strong>4.8/5</strong>
                    <span>Danh gia khach hang</span>
                </div>
                <div class="hero-stat">
                    <strong>24h</strong>
                    <span>Ho tro nhanh</span>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <img src="~/images/products/banner1.jpg" class="d-block w-100" style="height:320px;object-fit:cover;border-radius:24px;" alt="Banner phu kien dien thoai" />
        </div>
    </div>
</section>

<div class="section-head">
    <div>
        <h2>San pham moi nhat</h2>
        <p>Chon nhanh nhung mau phu kien dang duoc quan tam nhieu nhat.</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-xl-3">
            <div class="card product-card h-100">
                <a asp-controller="Home" asp-action="Detail" asp-route-id="@item.Id">
                    <div class="product-media">
                        @if (item.IsSale)
                        {
                            <span class="product-tag"><i class="fas fa-tag"></i> Sale</span>
                        }
                        <img src="~/images/products/@item.Image"
                             class="card-img-top"
                             alt="@item.Name"
                             onerror="this.src='https://via.placeholder.com/300x200?text=Linh+Kien+No+Image'">
                    </div>
                </a>

                <div class="card-body">
                    <h5 class="card-title">
                        <a asp-controller="Home" asp-action="Detail" asp-route-id="@item.Id">
                            @item.Name
                        </a>
                    </h5>

                    <p class="card-text product-desc">@item.Description</p>

                    <p class="card-text mb-0">
                        <span class="price-pill">Gia: @item.Price.ToString("N0") VND</span>
                    </p>
                    <p class="card-text mt-2 mb-0">
                        <small class="text-muted">Ton kho: @item.Stock</small>
                    </p>
                </div>

                <div class="card-footer text-center">
                    @if (item.Stock > 0)
                    {
                        <a asp-controller="Cart"
                           asp-action="AddToCart"
                           asp-route-id="@item.Id"
                           class="btn btn-brand w-100">
                            Them vao gio hang
                        </a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary w-100" disabled>Het hang</button>
                    }
                </div>
            </div>
        </div>
    }
</div>
