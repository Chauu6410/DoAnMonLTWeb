@model List<DoAnMonLTWeb.Models.CartItem>

<h2>Giỏ hàng</h2>

@if (!Model.Any())
{
    <p>Giỏ hàng đang trống</p>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Hình</th>
                    <th>Sản phẩm</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Tổng</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="~/images/products/@item.Product.Image"
                                 alt="@item.Product.Name"
                                 style="width:80px;height:80px;object-fit:cover;">
                        </td>
                        <td>@item.Product.Name</td>
                        <td>@item.Product.Price.ToString("N0") VNĐ</td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-2 flex-wrap">
                                <input type="hidden" name="id" value="@item.Product.Id" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" style="width:80px" />
                                <button type="submit" class="btn btn-sm btn-primary">Cập nhật</button>
                            </form>
                        </td>
                        <td>@((item.Product.Price * item.Quantity).ToString("N0")) VNĐ</td>
                        <td class="text-end">
                            <a asp-action="RemoveFromCart"
                               asp-route-id="@item.Product.Id"
                               class="btn btn-danger btn-sm">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <h3>
        Tổng tiền:
        <span style="color:red; font-weight:bold; font-size:20px;">
            @Model.Sum(x => x.Product.Price * x.Quantity).ToString("N0") VNĐ
        </span>
    </h3>

    <a asp-controller="Checkout"
       asp-action="Index"
       class="btn btn-success">
        Thanh toán
    </a>
}
