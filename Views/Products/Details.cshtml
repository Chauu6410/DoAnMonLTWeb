@model Product

<h2>Chi tiết sản phẩm</h2>

<div class="row">

<div class="col-md-6">
    <img src="@Model.Image" class="img-fluid">
</div>

<div class="col-md-6">

<h3>@Model.Name</h3>

<h4 class="text-danger">
@Model.Price VNĐ
</h4>

<p>
@Model.Description
</p>

<a class="btn btn-success">
Thêm vào giỏ hàng
</a>

</div>

</div>