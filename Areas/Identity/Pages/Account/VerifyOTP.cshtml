@page
@model VerifyOTPModel
@{
    ViewData["Title"] = "Xác thực Email";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-5">
                <h2 class="text-center mb-4">Nhập mã OTP</h2>
                <p class="text-muted text-center mb-4">
                    Một mã xác thực gồm 6 chữ số đã được gửi tới email <strong>@Model.Email</strong>.
                    <br />Vui lòng kiểm tra hộp thư (và thư mục Spam) để lấy mã.
                </p>

                <form method="post">
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="ReturnUrl" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.OtpCode" class="form-control text-center" style="font-size: 24px; letter-spacing: 5px;" autocomplete="off" placeholder="123456" maxlength="6" />
                        <label asp-for="Input.OtpCode">Mã OTP (6 chữ số)</label>
                        <span asp-validation-for="Input.OtpCode" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fs-5">Xác nhận</button>
                    
                    <div class="mt-4 text-center">
                        <p class="mb-0">Chưa nhận được mã?</p>
                        <button type="submit" asp-page-handler="Resend" class="btn btn-link text-decoration-none">Gửi lại mã OTP mới</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
