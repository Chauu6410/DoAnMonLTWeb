@model DoAnMonLTWeb.Models.Product
@{
    ViewData["Title"] = "Xoa san pham";
}

<h1 class="h3 mb-3">Xoa san pham</h1>
<p class="text-muted">Ban co chac muon xoa san pham nay?</p>

<dl class="row bg-white p-3 rounded shadow-sm">
    <dt class="col-sm-3">Ten</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Gia</dt>
    <dd class="col-sm-9">@Model.Price.ToString("N0") VNĐ</dd>
    <dt class="col-sm-3">Danh muc</dt>
    <dd class="col-sm-9">@Model.Category?.Name</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xoa</button>
    <a class="btn btn-secondary" asp-area="Admin" asp-controller="Products" asp-action="Index">Huy</a>
</form>
