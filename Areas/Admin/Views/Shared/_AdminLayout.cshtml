<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quan tri shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin Panel</a>
            <div class="navbar-nav me-auto">
                <a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="Index">San pham</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Category" asp-action="Index">Danh muc</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index">Don hang</a>
            </div>
            <div class="navbar-nav">
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Ve trang ban hang</a>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
